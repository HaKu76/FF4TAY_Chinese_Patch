<Window x:Class="ff4_patcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        Title="FF4 TAY 中文补丁" Height="570" Width="540"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseDown">
    <Grid>
        <Image Source="/background.png" Stretch="UniformToFill"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/><RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- Title bar -->
            <Border Grid.Row="0" Background="#CCFFFFFF"
                    BorderBrush="#30000000" BorderThickness="0,0,0,0.5"
                    MouseLeftButtonDown="Window_MouseDown">
                <Grid>
                    <TextBlock Text="FF4 TAY 中文补丁 v1.0.1" Foreground="#333"
                               FontFamily="Microsoft YaHei" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <Button Content="X" Width="32" Height="32" HorizontalAlignment="Right"
                            Click="Close_Click" Foreground="#666" Background="Transparent"
                            BorderThickness="0" FontSize="14" Cursor="Hand"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="130"/><RowDefinition Height="*"/><RowDefinition Height="100"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" VerticalAlignment="Bottom" Margin="0,0,0,15">
                    <TextBlock Text="最终幻想4：月之归还" Foreground="Black"
                               FontFamily="Microsoft YaHei" FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="简体中文补丁  v1.0.1" Foreground="#333"
                               FontFamily="Microsoft YaHei" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Row="1" Background="#AAFFFFFF" CornerRadius="8"
                        BorderBrush="#40000000" BorderThickness="1"
                        Margin="30,0,30,10" Padding="12">
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Hidden">
                        <TextBlock x:Name="LogText" Foreground="#1a2a3a"
                                   FontFamily="Microsoft YaHei" FontSize="12" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
                <Button Grid.Row="2" x:Name="InstallBtn" Content="安装补丁" Width="160" Height="48"
                        Click="Install_Click" Background="#CCFFFFFF" Foreground="#1a2a3a"
                        FontFamily="Microsoft YaHei" FontSize="15" FontWeight="Bold"
                        BorderBrush="#40000000" BorderThickness="1" Cursor="Hand"
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,12,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    Padding="20,8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
